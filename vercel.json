{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/goai-website run build",
  "outputDirectory": "artifacts/goai-website/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/healthz", "destination": "/api/healthz" },
    { "source": "/api/contact", "destination": "/api/contact" }
  ]
}
